# --llm(LangGraph 에이전트 분석)을 쓰려면 이 파일을 .env로 복사하고 채우세요.

# OpenAI (필수) — 변수명은 정확히 OPENAI_API_KEY 여야 합니다.
OPENAI_API_KEY=sk-...

# LangSmith 추적 (선택) — 키가 있으면 실행이 LangSmith에 기록됩니다.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true          # 키가 있으면 코드가 자동으로 켭니다(생략 가능)
# LANGSMITH_PROJECT=magic-analyzer
